# mcplex configuration — all values are optional (defaults shown)

# Ollama server URL
MCPLEX_OLLAMA_URL=http://localhost:11434

# Default model for generate/chat
MCPLEX_DEFAULT_MODEL=qwen3:8b

# Default embedding model
MCPLEX_EMBED_MODEL=nomic-embed-text

# Default vision model
MCPLEX_VISION_MODEL=llava

# ChromaDB persistent storage path
MCPLEX_CHROMA_PATH=./mcplex_data/chroma

# Default sampling temperature (0.0-2.0)
MCPLEX_DEFAULT_TEMPERATURE=0.7

# Default max tokens for generation
MCPLEX_DEFAULT_MAX_TOKENS=2048
